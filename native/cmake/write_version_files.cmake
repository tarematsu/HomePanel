if(DEFINED ENV{HOMEPANEL_BUILD_VERSION} AND NOT "$ENV{HOMEPANEL_BUILD_VERSION}" STREQUAL "")
  set(HOMEPANEL_BUILD_VERSION "$ENV{HOMEPANEL_BUILD_VERSION}")
else()
  string(TIMESTAMP HOMEPANEL_BUILD_VERSION "%y%m%d%H%M")
endif()

string(LENGTH "${HOMEPANEL_BUILD_VERSION}" HOMEPANEL_BUILD_VERSION_LENGTH)
if(HOMEPANEL_BUILD_VERSION_LENGTH EQUAL 10 AND HOMEPANEL_BUILD_VERSION MATCHES "^[0-9]+$")
  string(SUBSTRING "${HOMEPANEL_BUILD_VERSION}" 0 2 HOMEPANEL_V1)
  string(SUBSTRING "${HOMEPANEL_BUILD_VERSION}" 2 2 HOMEPANEL_V2)
  string(SUBSTRING "${HOMEPANEL_BUILD_VERSION}" 4 2 HOMEPANEL_V3)
  string(SUBSTRING "${HOMEPANEL_BUILD_VERSION}" 6 4 HOMEPANEL_V4)
  set(HOMEPANEL_VERSION_COMMA "${HOMEPANEL_V1},${HOMEPANEL_V2},${HOMEPANEL_V3},${HOMEPANEL_V4}")
elseif(HOMEPANEL_BUILD_VERSION MATCHES "^[0-9]+\\.[0-9]+\\.[0-9]+$")
  string(REPLACE "." "," HOMEPANEL_VERSION_COMMA "${HOMEPANEL_BUILD_VERSION}")
  set(HOMEPANEL_VERSION_COMMA "${HOMEPANEL_VERSION_COMMA},0")
else()
  message(FATAL_ERROR "HOMEPANEL_BUILD_VERSION must use yymmddhhmm or numeric major.minor.patch format")
endif()

configure_file("${INPUT_HOME_RC}" "${OUTPUT_HOME_RC}" @ONLY)
configure_file("${INPUT_UPDATER_RC}" "${OUTPUT_UPDATER_RC}" @ONLY)
configure_file("${INPUT_VERSION_H}" "${OUTPUT_VERSION_H}" @ONLY)
